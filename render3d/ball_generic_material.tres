[sub_resource type="Shader" id="Shader_n2gp1"]
code = "shader_type spatial;

uniform sampler2D tex_albedo;

instance uniform vec4 tint_color = vec4(1,1,1,1);

void fragment() {
	vec3 color = texture(tex_albedo, UV).rgb;
	color = color * tint_color.rgb;
	ALBEDO = color;
}

